#!/bin/bash
#SBATCH --partition=saarman-np
#SBATCH --account=saarman-np
#SBATCH --time=4:00:00
#SBATCH --mem=16G
#SBATCH --nodes=1
#SBATCH --cpus-per-task=8
#SBATCH --job-name="sample_stats_fast"
#SBATCH --mail-user=emily.calhoun@usu.edu
#SBATCH --mail-type=BEGIN,END,FAIL

module load bcftools

VCF_DIR=/uufs/chpc.utah.edu/common/home/u1055819/saarman-group/Cx_WGS/Cx_WGS_vcf
OUT_DIR=/uufs/chpc.utah.edu/common/home/u1055819/saarman-group/Cx_WGS/Cx_WGS_vcf

echo "=== Calculating per-sample stats (fast method) ==="

# Stage 1 stats
echo "Stage 1 stats..."
bcftools stats -s - ${VCF_DIR}/Culex_final_variants.vcf.gz > ${OUT_DIR}/stage1_stats.txt

# Stage 2 stats
echo "Stage 2 stats..."
bcftools stats -s - ${VCF_DIR}/Culex_stage2_bias_filtered.vcf.gz > ${OUT_DIR}/stage2_stats.txt

echo ""
echo "=== Processing results ==="

# Extract per-sample SNP counts and create comparison table
echo "Sample,Stage1_SNPs,Stage2_SNPs,Removed,Percent_Removed" > ${OUT_DIR}/per_sample_comparison.csv

# Get sample names
bcftools query -l ${VCF_DIR}/Culex_final_variants.vcf.gz | while read sample; do
    clean_name=$(basename $sample .markdup.bam)
    
    # Extract counts from stats files
    stage1=$(grep "^PSC" ${OUT_DIR}/stage1_stats.txt | grep -w "$sample" | cut -f4)
    stage2=$(grep "^PSC" ${OUT_DIR}/stage2_stats.txt | grep -w "$sample" | cut -f4)
    
    if [ ! -z "$stage1" ] && [ ! -z "$stage2" ]; then
        removed=$((stage1 - stage2))
        percent=$(awk "BEGIN {printf \"%.2f\", ($removed/$stage1)*100}")
        echo "$clean_name,$stage1,$stage2,$removed,$percent"
    fi
done >> ${OUT_DIR}/per_sample_comparison.csv

echo ""
echo "=== Complete! ==="
echo "Results saved to:"
echo "  ${OUT_DIR}/per_sample_comparison.csv"
echo ""
echo "Top 10 most filtered samples:"
sort -t',' -k5 -rn ${OUT_DIR}/per_sample_comparison.csv | head -11

echo ""
echo "Top 10 least filtered samples:"
sort -t',' -k5 -n ${OUT_DIR}/per_sample_comparison.csv | tail -10

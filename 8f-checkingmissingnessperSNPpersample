#!/bin/bash
#SBATCH --partition=saarman-np
#SBATCH --account=saarman-np
#SBATCH --time=1:00:00
#SBATCH --mem=8G
#SBATCH --nodes=1
#SBATCH --cpus-per-task=4
#SBATCH --job-name="check_missingness_fixed"
#SBATCH --mail-user=emily.calhoun@usu.edu
#SBATCH --mail-type=BEGIN,END,FAIL

module load bcftools

# Define input and output paths
MERGED_VCF=/uufs/chpc.utah.edu/common/home/u1055819/saarman-group/Cx_WGS/Cx_WGS_ddRAD_merged/merged_WGS_ddRAD_raw.vcf.gz
OUT_DIR=/uufs/chpc.utah.edu/common/home/u1055819/saarman-group/Cx_WGS/Cx_WGS_ddRAD_merged

echo "=== Checking Missingness in Merged VCF (FIXED VERSION) ==="
echo "Start time: $(date)"

# Check if input file exists
if [ ! -f "$MERGED_VCF" ]; then
    echo "Error: Input VCF file not found: $MERGED_VCF"
    exit 1
fi

echo "Input VCF: $MERGED_VCF"
echo "Output directory: $OUT_DIR"

# Get basic stats
echo "=== Basic VCF stats ==="
total_samples=$(bcftools query -l "$MERGED_VCF" | wc -l)
total_variants=$(bcftools view -H "$MERGED_VCF" | wc -l)
echo "Number of samples: $total_samples"
echo "Number of variants: $total_variants"

# Calculate missingness per SNP (manually)
echo "=== Calculating missingness per SNP ==="
echo -e "CHROM\tPOS\tID\tREF\tALT\tN_MISSING\tN_SAMPLES\tF_MISSING" > "$OUT_DIR/missingness_per_snp.txt"

# Process each variant to count missing genotypes
bcftools query -f '%CHROM\t%POS\t%ID\t%REF\t%ALT[\t%GT]\n' "$MERGED_VCF" | while read line; do
    # Split the line into components
    chrom=$(echo "$line" | awk '{print $1}')
    pos=$(echo "$line" | awk '{print $2}')
    id=$(echo "$line" | awk '{print $3}')
    ref=$(echo "$line" | awk '{print $4}')
    alt=$(echo "$line" | awk '{print $5}')
    
    # Count missing genotypes in this line (columns 6 onward)
    missing_count=$(echo "$line" | awk '{
        missing = 0
        for(i=6; i<=NF; i++) {
            if($i == "./." || $i == ".|.") missing++
        }
        print missing
    }')
    
    # Calculate missing frequency
    missing_freq=$(awk -v missing="$missing_count" -v total="$total_samples" 'BEGIN { printf "%.4f", missing/total }')
    
    # Output result
    echo -e "$chrom\t$pos\t$id\t$ref\t$alt\t$missing_count\t$total_samples\t$missing_freq" >> "$OUT_DIR/missingness_per_snp.txt"
done

echo "SNP missingness calculation complete"

# Calculate missingness per sample (keep the existing code that worked)
echo "=== Calculating missingness per sample ==="
bcftools query -l "$MERGED_VCF" > "$OUT_DIR/sample_list.txt"

# Create header for sample missingness file
echo -e "SAMPLE\tN_MISSING\tN_SITES\tF_MISSING" > "$OUT_DIR/missingness_per_sample.txt"

# Calculate missingness for each sample using awk
while read sample; do
    # Count missing genotypes for this sample
    missing_count=$(bcftools view -s "$sample" "$MERGED_VCF" | bcftools query -f '[%GT]\n' | awk '
        BEGIN { missing = 0 }
        /\.\/\./ { missing++ }
        /\|\|/ { missing++ }
        END { print missing }
    ')
    
    # Calculate missing frequency using awk
    missing_freq=$(awk -v missing="$missing_count" -v total="$total_variants" 'BEGIN { printf "%.4f", missing/total }')
    
    echo -e "$sample\t$missing_count\t$total_variants\t$missing_freq" >> "$OUT_DIR/missingness_per_sample.txt"
done < "$OUT_DIR/sample_list.txt"

# Generate summary statistics using awk
echo "=== Generating summary statistics ==="

# Summary for SNPs
echo "=== SNP Missingness Summary ===" > "$OUT_DIR/missingness_summary_fixed.txt"
snp_count=$(tail -n +2 "$OUT_DIR/missingness_per_snp.txt" | wc -l)
echo "Total SNPs: $snp_count" >> "$OUT_DIR/missingness_summary_fixed.txt"

# Count SNPs with different missingness thresholds
tail -n +2 "$OUT_DIR/missingness_per_snp.txt" | awk '$8 > 0.1' | wc -l > temp_count
echo "SNPs with >10% missing: $(cat temp_count)" >> "$OUT_DIR/missingness_summary_fixed.txt"

tail -n +2 "$OUT_DIR/missingness_per_snp.txt" | awk '$8 > 0.2' | wc -l > temp_count
echo "SNPs with >20% missing: $(cat temp_count)" >> "$OUT_DIR/missingness_summary_fixed.txt"

tail -n +2 "$OUT_DIR/missingness_per_snp.txt" | awk '$8 > 0.5' | wc -l > temp_count
echo "SNPs with >50% missing: $(cat temp_count)" >> "$OUT_DIR/missingness_summary_fixed.txt"

echo "" >> "$OUT_DIR/missingness_summary_fixed.txt"

# Summary for samples (reuse existing calculation)
echo "=== Sample Missingness Summary ===" >> "$OUT_DIR/missingness_summary_fixed.txt"
tail -n +2 "$OUT_DIR/missingness_per_sample.txt" | wc -l > temp_count
echo "Total samples: $(cat temp_count)" >> "$OUT_DIR/missingness_summary_fixed.txt"

tail -n +2 "$OUT_DIR/missingness_per_sample.txt" | awk '$4 > 0.1' | wc -l > temp_count
echo "Samples with >10% missing: $(cat temp_count)" >> "$OUT_DIR/missingness_summary_fixed.txt"

tail -n +2 "$OUT_DIR/missingness_per_sample.txt" | awk '$4 > 0.2' | wc -l > temp_count
echo "Samples with >20% missing: $(cat temp_count)" >> "$OUT_DIR/missingness_summary_fixed.txt"

tail -n +2 "$OUT_DIR/missingness_per_sample.txt" | awk '$4 > 0.5' | wc -l > temp_count
echo "Samples with >50% missing: $(cat temp_count)" >> "$OUT_DIR/missingness_summary_fixed.txt"

# Clean up temp file
rm -f temp_count

echo ""
echo "=== Output files created ==="
echo "SNP missingness: $OUT_DIR/missingness_per_snp.txt"
echo "Sample missingness: $OUT_DIR/missingness_per_sample.txt"
echo "Summary statistics: $OUT_DIR/missingness_summary_fixed.txt"

echo ""
echo "End time: $(date)"
echo "=== Complete ==="
